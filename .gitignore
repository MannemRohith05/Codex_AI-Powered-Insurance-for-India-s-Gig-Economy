# Root .gitignore — GigShield

# Dependencies
node_modules/
**/node_modules/

# Environment variables — NEVER commit these
.env
**/.env

# Build outputs
dist/
build/
**/dist/
**/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
error.log
error-utf8.log
build.log

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Vite cache
.vite/
**/.vite/
