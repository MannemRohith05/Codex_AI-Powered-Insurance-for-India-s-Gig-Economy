# ─── IMPORTANT FOR HACKATHON JUDGES ─────────────────────────────────────────────
# Please check the bottom of README.md for the Google Drive link to the live .env keys!
# Drive link: https://drive.google.com/file/d/1nUZw3ACYa2UoLba6hwHUTHAn3AAzMAcH/view?usp=sharing
# ───────────────────────────────────────────────────────────────────────────────

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# MongoDB Atlas (recommended) — create free cluster at mongodb.com/atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/gigshield?appName=Cluster0
# OR local MongoDB:
# MONGO_URI=mongodb://localhost:27017/gigshield


# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# ─── External APIs (optional — app works without these in dev mode) ─────────────

# Twilio (OTP — leave as-is in dev, OTP is logged to console instead)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OpenWeatherMap (weather poller)
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Sandbox.co.in (Aadhaar KYC)
SANDBOX_API_KEY=your_sandbox_api_key
SANDBOX_API_SECRET=your_sandbox_api_secret

# Razorpay (payments — app uses mock mode if keys are not set)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_PAYOUT_ACCOUNT=your_razorpay_payout_account_number

# Redis (optional — app works without it)
REDIS_URL=redis://localhost:6379
